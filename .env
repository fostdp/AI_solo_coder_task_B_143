# ============================================================
# 连弩动力学仿真系统 - 环境变量配置
# ============================================================

# ---------- PostgreSQL / TimescaleDB ----------
POSTGRES_DB=crossbow_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- MQTT Broker ----------
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ---------- Backend ----------
BACKEND_PORT=8080
PPROF_PORT=6060

# ---------- Frontend ----------
FRONTEND_PORT=3000

# ---------- Prometheus ----------
PROM_PORT=9090

# ---------- Grafana ----------
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---------- 传感器模拟器 (profile: simulator) ----------
SIM_CROSSBOW_ID=crossbow-001
SIM_MODE=normal        # normal | fatigue | accelerated | jammed | string_break
SIM_INTERVAL=1         # 上报间隔（秒）
SIM_MAGAZINE_SIZE=10   # 箭匣容量（发）
SIM_INITIAL_FATIGUE=0  # 初始弓弦疲劳 0.0~1.0

# ---------- 第二台模拟器 (profile: simulator2) ----------
SIM2_MODE=fatigue
SIM2_INTERVAL=2
SIM2_MAGAZINE_SIZE=6
